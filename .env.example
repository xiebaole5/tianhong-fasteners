# .env.example
#
# 环境变量模板
# ============================================================
# 用法：cp .env.example .env
# 然后编辑 .env，填入所有带 <...> 占位符的变量值。
#
# ⚠️  安全注意：
#   - .env 文件已在 .gitignore 中排除，绝不要将其提交到 Git 仓库。
#   - 所有带 SECRET/KEY/TOKEN/PASSWORD 的变量均为敏感信息。
#   - 生产环境建议使用密钥管理服务（如 HashiCorp Vault）存储以下变量。
# ============================================================

# ─── 企业微信（WeCom）配置 ─────────────────────────────────────────────────
# 在企业微信管理后台 → 我的企业 → 企业信息 中获取
WECHAT_CORP_ID=<your_corp_id>

# 在企业微信管理后台 → 应用管理 → 自建应用 中获取
WECHAT_AGENT_ID=<your_agent_id>

# 自建应用的 Secret（注意：每次点击"查看"会刷新，请妥善保存）
WECHAT_SECRET=<your_app_secret>

# 接收消息时的验签 Token（在配置企业微信回调时自定义，建议随机 32 位字符串）
WECHAT_TOKEN=<your_random_token_32chars>

# EncodingAESKey（企业微信消息加解密密钥，43位字符串）
# TODO: 当前 bridge 仅支持明文模式，加密模式需在生产前实现 WXBizMsgCrypt
WECHAT_ENCODING_AES_KEY=<your_encoding_aes_key_43chars>

# ─── Bridge 内部鉴权 ───────────────────────────────────────────────────────
# 用于 /internal/trigger 端点的内部鉴权密钥（请求头 X-Bridge-Secret）
# 建议：openssl rand -hex 32
BRIDGE_SECRET=<your_random_bridge_secret>

# ─── 本地模型 API ──────────────────────────────────────────────────────────
# text-generation-webui（OpenAI 兼容 API）
MODEL_API_BASE=http://localhost:5000/v1

# 或 Ollama：
# MODEL_API_BASE=http://localhost:11434

# 后端类型：webui | ollama
MODEL_BACKEND=webui

# 模型名称（GGUF 文件名或 Ollama 模型标签）
# text-generation-webui: 文件名（不含路径，放在 models/ 目录下）
MODEL_NAME=Qwen3-8B-Q4_K_M.gguf

# 或 Ollama:
# MODEL_NAME=qwen3:8b

# 模型最大输出 Token 数（建议 256-1024，过大会增加响应延迟）
MAX_TOKENS=512

# 系统提示词（可选，默认为中文助手提示）
SYSTEM_PROMPT=你是天宏紧固件公司的智能助手，请用中文简洁专业地回答问题。

# ─── 模型路径（Docker 挂载）───────────────────────────────────────────────
# 宿主机上存放模型文件的目录（将被挂载到容器内）
MODELS_DIR=./models

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────
# 从 Cloudflare Dashboard → Zero Trust → Networks → Tunnels 获取
# 使用 Docker 方式部署 cloudflared 时需要此 Token
CLOUDFLARED_TOKEN=<your_cloudflared_tunnel_token>

# ─── 服务路径配置 ──────────────────────────────────────────────────────────
# 白名单脚本目录（bridge 只允许执行此目录下的脚本）
SCRIPTS_DIR=/app/scripts

# 审计日志目录
LOG_DIR=/app/logs

# ─── 可选：模型推理参数 ────────────────────────────────────────────────────
# GPU 层数（值越大，越多层在 GPU 计算，速度越快但显存消耗越多）
# RTX 4070 8GB + Q4_K_M 建议值：35
N_GPU_LAYERS=35

# 上下文窗口大小（token 数，越大显存消耗越多）
# RTX 4070 8GB + Q4_K_M 建议值：4096
N_CTX=4096
